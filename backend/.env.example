# Server
PORT=5000
NODE_ENV=development

# MongoDB (Atlas or local)
# Replace with your MongoDB connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/farm_marketplace?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRE=7d

# Blockchain relayer (local Hardhat defaults shown)
ETHEREUM_NODE_URL=http://127.0.0.1:8545
ETHEREUM_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Razorpay (optional — leave blank to disable online payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
