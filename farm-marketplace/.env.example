# Copy to .env and fill in local values. Never commit .env.

# Backend API base URL (use your machine LAN IP for physical devices)
# Android emulator: http://10.0.2.2:5000/api
# iOS simulator:    http://localhost:5000/api
EXPO_PUBLIC_API_URL=http://localhost:5000/api

# Cloudinary (optional — can also be set via app.json extra)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
EXPO_PUBLIC_CLOUDINARY_API_KEY=
EXPO_PUBLIC_CLOUDINARY_API_SECRET=
